NODE_ENV=development #REQUIRED
PORT=3333 #REQUIRED

REFRESH_TOKEN_DAYS=7 #OPTIONAL

SERVER_URL= #REQUIRED
PRODUCT_NAME="My app name"
MONGODB_URL= #REQUIRED
FRONTEND_URL= #REQUIRED

JWT_ACCESS_SECRET= #REQUIRED
JWT_ACCESS_EXPIRES_IN='15m' #Must be valid jwt time format e.g. 7d | OPTIONAL

# SMTP
SMTP_HOST= #REQUIRED
SMTP_PORT= #REQUIRED
SMTP_SECURE=true #REQUIRED
SMTP_USER= #REQUIRED
SMTP_PASS= #REQUIRED
SMTP_FROM= #REQUIRED e.g. "Reviewlico <no-reply@yourdomain.com>"

# Redis — OPTIONAL
# When set, a distributed Redis store is used for rate limiting (recommended for multi-instance prod).
# Falls back to an in-memory store when not set (single-instance only).
# REDIS_URL=redis://localhost:6379